# front/.env.local にコピーして値を設定する
#   cp .env.example .env.local
# 取得手順は docs/09-architecture-specification.md「ローカル開発セットアップ」を参照。

# --- データベース（Prisma が参照） ---
# Supabase の接続文字列。Direct が不可なら Session pooler の URI を使う。
DATABASE_URL=postgresql://postgres:<DB_PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres

# --- Supabase Auth（クライアント + サーバーのトークン検証） ---
NEXT_PUBLIC_SUPABASE_URL=https://<PROJECT_REF>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<SUPABASE_ANON_KEY>

# --- 管理者 allowlist（サーバー側のみ・クライアントへ露出しない） ---
ADMIN_EMAIL=you@example.com

# --- OAuth リダイレクト先のベース URL ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
